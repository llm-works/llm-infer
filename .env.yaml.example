# Local environment configuration
# Copy this file to .env.yaml and customize for your setup
#
#   cp .env.yaml.example .env.yaml
#
# .env.yaml is gitignored and will not be committed.

# Paths to local model storage
paths:
  models:
    # HuggingFace format models (used by native & vllm engines)
    huggingface: !path ~/models/huggingface
    # Ollama format models (used by ollama engine)
    ollama: !path ~/models/ollama

  # LoRA adapters
  adapters: !path ~/models/adapters

  # Ollama binary (for local installation, or "ollama" to use PATH)
  ollama_binary: ollama
